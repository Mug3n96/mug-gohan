# API key for logging into the app (any string)
API_KEY=change_me

# Backend
PORT=3000
NODE_ENV=production
DATA_DIR=/app/data

# ---------------------------------------------------------------------------
# Ollama – Option A: Local Ollama container (default)
# ---------------------------------------------------------------------------
# The Ollama container runs as a separate Docker service.
# Local models require no account but need RAM (~7 GB for small models).
# Cloud models (e.g. gemma4:31b-cloud) require an ollama.com account and
# a one-time "docker compose exec ollama ollama signin" after first start.
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:e2b
# OLLAMA_MODEL=gemma4:31b-cloud  # Cloud model (no local RAM needed)

# ---------------------------------------------------------------------------
# Ollama – Option B: Direct ollama.com API (no local Ollama container)
# ---------------------------------------------------------------------------
# If you don't want to run the Ollama container at all, you can use the
# ollama.com cloud API directly. To do so:
#   1. Create an API key at: https://ollama.com/settings/keys
#   2. Remove or comment out the ollama service in docker-compose.yml
#   3. Set these variables instead:
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=gemma4:31b-cloud
# OLLAMA_API_KEY=your-api-key
